package com.rays.inheritance;

public class Student {
	private String rollNo;
	private int marks;
	
	public void setRollNo(String rollNo) {
		this.rollNo=rollNo;
	}
	
	public void setMarks(int marks) {
		this.marks=marks;
		
	}
	public String getRollNO() {
		return rollNo;
	}
	public int getMarks() {
		return marks;
	}
}
